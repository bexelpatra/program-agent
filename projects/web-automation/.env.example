# web-automation 환경변수 템플릿
# 사용법: 이 파일을 .env로 복사한 뒤 값을 채워넣는다.
#   cp .env.example .env
#
# .env 파일은 .gitignore 에 의해 저장소에 커밋되지 않는다.
# Config.get() (src/core/config.py) 가 WA_ 접두사 환경변수를 자동으로
# 읽어서 YAML 설정보다 우선 적용한다.

# === 카카오 계정 (티스토리 로그인) ===
# 티스토리는 카카오 계정으로 로그인한다. 아래 값은 카카오 ID/비밀번호.
WA_ACCOUNT_EMAIL=your_kakao_id@example.com
WA_ACCOUNT_PASSWORD=your_kakao_password

# === 네이버 IMAP 계정 (인증번호 수신용) ===
# 카카오 로그인 과정에서 발송되는 인증번호를 Naver 메일함에서 읽어오기 위함.
# Naver 메일 > 환경설정 > POP3/IMAP 설정 > IMAP 사용함 필수.
# 2단계 인증 사용 시 애플리케이션 비밀번호 발급 필요.
WA_NAVER_IMAP_EMAIL=your_naver_id@naver.com
WA_NAVER_IMAP_PASSWORD=your_naver_app_password

# === 텔레그램 봇 (선택) ===
# BotFather 에서 봇 생성 후 토큰 발급. chat_id 는 봇과 대화 시작 후 조회.
# WA_TELEGRAM_BOT_TOKEN=
# WA_TELEGRAM_CHAT_ID=
