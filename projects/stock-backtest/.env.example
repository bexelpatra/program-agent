# --- DB (Docker Compose 의 postgres 서비스와 연동) ---
POSTGRES_USER=stock
POSTGRES_PASSWORD=stock
POSTGRES_DB=stock_backtest
POSTGRES_PORT=5432

# 운영 DB 연결 문자열 (backend 가 사용)
DATABASE_URL=postgresql://stock:stock@localhost:5432/stock_backtest

# 테스트 전용 DB 연결 문자열 (pytest 실행 시 사용)
DATABASE_URL_TEST=postgresql://stock:stock@localhost:5432/stock_backtest_test

# --- 애플리케이션 ---
# 한국 거주자 기준 리포팅 + KR 장 캘린더 기준 시각
TZ=Asia/Seoul

# 기본 base_currency (사용자가 백테스트 생성 시 항상 명시하지만, dev 편의용 디폴트)
DEFAULT_BASE_CURRENCY=KRW

# --- API ---
# FastAPI 서버 포트 (기본 8001 - host 8000 은 ethics-study 전용)
BACKEND_PORT=8001

# Next.js 가 호출할 백엔드 API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# --- Phase 2 (테마주 추적 모듈) ---
# TODO: 네이버 데이터랩 검색 API 인증 — developers.naver.com 에서 애플리케이션 등록 후 발급.
# 미발급 상태에서는 NaverDataLabSource 가 비활성화되고 화면 5 관심도 오버레이에 "관심도 데이터 없음" 표기 (graceful degradation).
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
